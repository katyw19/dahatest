rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function isGroupMember(groupId) {
      return exists(/databases/$(database)/documents/groups/$(groupId)/members/$(request.auth.uid));
    }

    function isGroupAdmin(groupId) {
      return isGroupMember(groupId) &&
        get(/databases/$(database)/documents/groups/$(groupId)/members/$(request.auth.uid)).data.role == 'admin';
    }

    // ── Groups ──────────────────────────────────────────────────────
    // Any signed-in user can read (needed for join flow / invite lookup).
    // Only admins can update; any authenticated user can create.
    match /groups/{groupId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn();
      allow update: if isSignedIn() && isGroupAdmin(groupId);
      allow delete: if false;
    }

    // ── Members ─────────────────────────────────────────────────────
    // Members can read all member docs in their group.
    // Members can update their OWN doc OR another member's doc (trust score from reviews).
    // Admins can create/update any member doc.
    match /groups/{groupId}/members/{uid} {
      allow read: if isSignedIn() && isGroupMember(groupId);
      allow create: if isSignedIn() && (isGroupAdmin(groupId) || request.auth.uid == uid);
      allow update: if isSignedIn() && isGroupMember(groupId);
      allow delete: if false;
    }

    // ── Join Requests ───────────────────────────────────────────────
    match /groups/{groupId}/joinRequests/{requestId} {
      allow create: if isSignedIn();
      allow read, update: if isSignedIn() && (isGroupAdmin(groupId) || request.auth.uid == requestId);
      allow delete: if false;
    }

    // ── Posts ────────────────────────────────────────────────────────
    match /groups/{groupId}/posts/{postId} {
      allow read: if isSignedIn() && isGroupMember(groupId);
      allow create: if isSignedIn() && isGroupMember(groupId);
      allow update: if isSignedIn() && isGroupMember(groupId) &&
        (resource.data.authorUid == request.auth.uid || isGroupAdmin(groupId));
      allow delete: if isSignedIn() && isGroupMember(groupId) &&
        (resource.data.authorUid == request.auth.uid || isGroupAdmin(groupId));
    }

    // ── Offers on Posts ─────────────────────────────────────────────
    match /groups/{groupId}/posts/{postId}/offers/{offerId} {
      allow read: if isSignedIn() && isGroupMember(groupId);
      allow create: if isSignedIn() && isGroupMember(groupId);
      allow update: if isSignedIn() && isGroupMember(groupId);
      allow delete: if false;
    }

    // ── Threads (chat) ──────────────────────────────────────────────
    match /groups/{groupId}/threads/{threadId} {
      allow read: if isSignedIn() && isGroupMember(groupId);
      allow create: if isSignedIn() && isGroupMember(groupId);
      allow update: if isSignedIn() && isGroupMember(groupId);
      allow delete: if false;
    }

    // ── Messages ────────────────────────────────────────────────────
    match /groups/{groupId}/threads/{threadId}/messages/{messageId} {
      allow read: if isSignedIn() && isGroupMember(groupId);
      allow create: if isSignedIn() && isGroupMember(groupId);
      allow update, delete: if false;
    }

    // ── Reviews ─────────────────────────────────────────────────────
    match /groups/{groupId}/threads/{threadId}/reviews/{reviewerUid} {
      allow create, update: if isSignedIn() && isGroupMember(groupId) && request.auth.uid == reviewerUid;
      allow read: if isSignedIn() && isGroupMember(groupId);
      allow delete: if false;
    }

    // ── Announcements ───────────────────────────────────────────────
    match /groups/{groupId}/announcements/{announcementId} {
      allow read: if isSignedIn() && isGroupMember(groupId);
      allow create, update, delete: if isSignedIn() && isGroupAdmin(groupId);
    }

    // ── Reports ─────────────────────────────────────────────────────
    match /groups/{groupId}/reports/{reportId} {
      allow create: if isSignedIn() && isGroupMember(groupId);
      allow read, update: if isSignedIn() &&
        (isGroupAdmin(groupId) || resource.data.createdByUid == request.auth.uid);
      allow delete: if false;
    }

    // ── Admin Actions (audit log) ───────────────────────────────────
    match /groups/{groupId}/adminActions/{actionId} {
      allow read: if isSignedIn() && isGroupAdmin(groupId);
      allow create, update: if isSignedIn() && isGroupAdmin(groupId);
      allow delete: if false;
    }

    // ── Admin Review Notes ──────────────────────────────────────────
    match /groups/{groupId}/adminReviewNotes/{noteId} {
      allow read: if isSignedIn() && isGroupAdmin(groupId);
      allow create, update: if isSignedIn() && isGroupMember(groupId);
      allow delete: if false;
    }

    // ── User Profiles ───────────────────────────────────────────────
    // Any signed-in user can read profiles (needed for display names/avatars).
    // Only the owner can write their own profile.
    match /users/{uid} {
      allow read: if isSignedIn();
      allow write: if isSignedIn() && request.auth.uid == uid;
    }

    // ── User Memberships Mirror ─────────────────────────────────────
    match /users/{uid}/memberships/{membershipId} {
      allow read: if isSignedIn() && request.auth.uid == uid;
      allow write: if isSignedIn() && (request.auth.uid == uid || isGroupAdmin(membershipId));
    }

    // ── User Join Requests Mirror ───────────────────────────────────
    match /users/{uid}/joinRequests/{groupId} {
      allow read: if isSignedIn() && request.auth.uid == uid;
      allow write: if isSignedIn() && (request.auth.uid == uid || isGroupAdmin(groupId));
    }

    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
